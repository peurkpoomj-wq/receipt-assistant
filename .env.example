# ============================================================
# LINE Messaging API
# ได้จาก: LINE Developers Console → Your Channel → Basic settings
# ============================================================
LINE_CHANNEL_SECRET=your_line_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here

# ============================================================
# OpenAI API (GPT-4o Vision)
# ได้จาก: platform.openai.com/api-keys
# ============================================================
OPENAI_API_KEY=sk-...your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# ============================================================
# Google Sheets API (Service Account)
# วิธีตั้งค่า:
#   1. Google Cloud Console → Create Service Account
#   2. Download JSON key → วางไว้ที่ credentials/google-service-account.json
#   3. Share your Google Sheet กับ service account email (Editor)
# ============================================================
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./credentials/google-service-account.json
# หรือจะใส่ JSON ทั้งก้อนใน env var นี้แทน (สำหรับ deploy บน cloud):
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_from_url_here
GOOGLE_SHEET_NAME=Expenses

# ============================================================
# App Config
# ============================================================
PORT=3000
NODE_ENV=development
